# Network
SYSLOG_PORT=5514
HTTP_PORT=3000

# Database
DB_PATH=./data/events.db
RETENTION_DAYS=60

# Enrichment (Phase 4)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb
ABUSEIPDB_API_KEY=
ABUSEIPDB_CACHE_HOURS=24
RDNS_ENABLED=false
RDNS_TIMEOUT_MS=2000

# Performance
INSERT_BATCH_SIZE=50
INSERT_BATCH_INTERVAL_MS=500
ENRICHMENT_CONCURRENCY=5
WS_BROADCAST_THROTTLE_MS=100

# Logging
LOG_LEVEL=info
LOG_RAW_MESSAGES=false
